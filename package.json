{
  "name": "poeticui",
  "private": true,
  "license": "Apache-2.0",
  "description": "Poetic UI — design tokens, neutral React primitives, and technical-content primitives. Open source under Apache-2.0.",
  "packageManager": "bun@1.3.11",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "storybook": "bun --cwd packages/components storybook",
    "storybook:build": "bun --cwd packages/components storybook:build",
    "changeset": "changeset",
    "version": "changeset version && bun install --lockfile-only",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "turbo": "^2.8.21",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "@headlessui/react": "2.2.10"
  }
}
