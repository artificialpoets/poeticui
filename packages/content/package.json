{
  "name": "@poeticui/content",
  "version": "0.1.0",
  "description": "Poetic UI — primitives for rendering technical content (code, math, persistent tabs). Usable in any React app. Opt-in: consumers who don't install this package pay zero bytes.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/artificialpoets/poeticui.git",
    "directory": "packages/content"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "files": [
    "src",
    "styles"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": [
    "./styles/*.css",
    "./src/styles/*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./code-block": "./src/code-block.tsx",
    "./math": "./src/math.tsx",
    "./persistent-tabs": "./src/persistent-tabs.tsx",
    "./package-manager-tabs": "./src/package-manager-tabs.tsx",
    "./language-tabs": "./src/language-tabs.tsx",
    "./pref-store": "./src/pref-store.ts",
    "./storage-keys": "./src/utils/storage-keys.ts",
    "./styles/code-block": "./styles/code-block.css",
    "./styles/katex": "./styles/katex.css"
  },
  "scripts": {
    "lint": "eslint src/",
    "build": "echo '@poeticui/content: source-only package, no build step'",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@poeticui/components": "*",
    "@poeticui/tokens": "*",
    "@types/katex": "^0.16.8",
    "class-variance-authority": "^0.7.1",
    "katex": "^0.16.45",
    "prop-types": "^15.8.1",
    "react-katex": "^3.1.0",
    "shiki": "^4.0.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "clsx": "^2.1.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-filename-rules": "^1.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "next": "^16.2.4",
    "prettier": "^3.6.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.2"
  }
}
